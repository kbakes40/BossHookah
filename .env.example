# Client (Vite) — required for login and PostgREST from the browser.
# Supabase Dashboard → Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=

# Optional — defaults to https://sjmrdnrneknzqiojtevm.supabase.co in shared/const.ts
# VITE_SUPABASE_URL=

# Server — service role; keep secret; used for admin JWT verification and server writes
# SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud Console → OAuth 2.0 client → Authorized redirect URIs (exact):
# https://sjmrdnrneknzqiojtevm.supabase.co/auth/v1/callback
